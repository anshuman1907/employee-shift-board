{
    "info": {
        "name": "Shift Board API",
        "_postman_id": "shift-board-sample",
        "description": "Quick collection for the Employee Shift Board API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Login",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"hire-me@anshumat.org\",\n  \"password\": \"HireMe@2025!\"\n}"
                },
                "url": {
                    "raw": "http://localhost:4000/login",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "4000",
                    "path": [
                        "login"
                    ]
                }
            }
        },
        {
            "name": "Get Employees",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:4000/employees",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "4000",
                    "path": [
                        "employees"
                    ]
                }
            }
        },
        {
            "name": "Get Shifts",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:4000/shifts",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "4000",
                    "path": [
                        "shifts"
                    ]
                }
            }
        },
        {
            "name": "Create Shift (admin)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"employee_code\": \"E002\",\n  \"date\": \"2025-12-15\",\n  \"start_time\": \"09:00\",\n  \"end_time\": \"13:00\"\n}"
                },
                "url": {
                    "raw": "http://localhost:4000/shifts",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "4000",
                    "path": [
                        "shifts"
                    ]
                }
            }
        }
    ]
}